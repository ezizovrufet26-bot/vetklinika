# ============================================================
# WhatsApp Onboarding — Ortam Degiskenleri
# Bu dosyayi .env olarak kopyalayin ve degerleri doldurun.
# ============================================================

# Server
PORT=3000

# --- Notion (zorunlu) ---
# Notion integration token (https://www.notion.so/my-integrations)
NOTION_API_KEY=<NOTION_TOKEN>
# Onboarding takip database ID'si
NOTION_DATABASE_ID=<NOTION_DB_ID>

# --- ManyChat (zorunlu) ---
MANYCHAT_API_TOKEN=<MANYCHAT_API_TOKEN>
# 7 gunluk drip akisinin her gunu icin ManyChat flow ID'si
MANYCHAT_FLOW_DAY_0=<MANYCHAT_FLOW_ID>
MANYCHAT_FLOW_DAY_1=<MANYCHAT_FLOW_ID>
MANYCHAT_FLOW_DAY_2=<MANYCHAT_FLOW_ID>
MANYCHAT_FLOW_DAY_3=<MANYCHAT_FLOW_ID>
MANYCHAT_FLOW_DAY_4=<MANYCHAT_FLOW_ID>
MANYCHAT_FLOW_DAY_5=<MANYCHAT_FLOW_ID>
MANYCHAT_FLOW_DAY_6=<MANYCHAT_FLOW_ID>
# ManyChat custom field ID'leri
MANYCHAT_FIELD_ONBOARDING_NAME=<MANYCHAT_FIELD_ID>
MANYCHAT_FIELD_WHATSAPP_PHONE=<MANYCHAT_FIELD_ID>

# --- Groq (zorunlu — telefon validasyonu) ---
GROQ_API_KEY=<GROQ_API_KEY>

# --- Webhook auth (zorunlu — yoksa boot coker) ---
WEBHOOK_SECRET=<RASTGELE_GIZLI_DEGER>

# --- Admin endpoint auth (opsiyonel) ---
ADMIN_SECRET=<RASTGELE_GIZLI_DEGER>

# --- Resend (opsiyonel — email fallback) ---
RESEND_API_KEY=<RESEND_API_KEY>
RESEND_FROM_EMAIL=Onboarding <onboarding@example.com>
# Sistem uyari mailleri bu adrese gider
ADMIN_ALERT_EMAIL=admin@example.com

# --- WhatsApp Business (opsiyonel — hibrit fallback CTA) ---
WA_BUSINESS_PHONE=<WA_BUSINESS_PHONE>

# --- Cron ---
CRON_TIMEZONE=Europe/Istanbul
CRON_SCHEDULE=0 12 * * *
